<%- include('layout') %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h2 class="text-lg font-semibold text-gray-900">Messages du chatbot</h2>
    <p class="text-sm text-gray-500"><%= total.toLocaleString('fr-BE') %> message(s) au total</p>
  </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="divide-y divide-gray-100">
    <% messages.forEach(m => { %>
      <div class="px-5 py-4 hover:bg-gray-50">
        <div class="flex items-start justify-between mb-2">
          <div class="flex items-center space-x-3">
            <div class="w-8 h-8 bg-<%= m.user_id ? 'blue' : 'gray' %>-600 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-<%= m.user_id ? 'user' : 'user-secret' %> text-white text-xs"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= m.fullname || 'Invité (session)' %></p>
              <p class="text-xs text-gray-400"><%= m.email || m.session_id?.substring(0,16) + '...' %></p>
            </div>
          </div>
          <span class="text-xs text-gray-400"><%= new Date(m.created_at).toLocaleString('fr-BE') %></span>
        </div>
        <div class="ml-11">
          <div class="mb-1">
            <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">Question:</span>
            <p class="text-sm text-gray-800 mt-0.5"><%= m.question %></p>
          </div>
          <% if (m.answer) { %>
            <div class="mt-2 border-l-2 border-green-300 pl-3">
              <span class="text-xs font-semibold text-green-600 uppercase tracking-wide">Réponse:</span>
              <p class="text-sm text-gray-600 mt-0.5 line-clamp-3"><%= m.answer.substring(0, 300) %><%= m.answer.length > 300 ? '...' : '' %></p>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
    <% if (messages.length === 0) { %>
      <div class="py-16 text-center text-gray-400">
        <i class="fas fa-comments text-4xl mb-3 block"></i>
        <p>Aucun message dans le chatbot</p>
      </div>
    <% } %>
  </div>
  <% if (pages > 1) { %>
    <div class="border-t border-gray-100 px-5 py-3 flex items-center justify-between">
      <p class="text-sm text-gray-500">Page <%= page %> / <%= pages %></p>
      <div class="flex space-x-1">
        <% for (let i = Math.max(1, page-4); i <= Math.min(pages, page+4); i++) { %>
          <a href="?page=<%= i %>"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-sm <%= i === page ? 'bg-blue-600 text-white' : 'hover:bg-gray-100 text-gray-600' %>">
            <%= i %>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
<%- include('layout_end') %>

