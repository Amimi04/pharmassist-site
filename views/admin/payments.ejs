<%- include('layout') %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h2 class="text-lg font-semibold text-gray-900">Paiements</h2>
    <p class="text-sm text-gray-500"><%= total %> paiement(s) au total</p>
  </div>
  <% if (revenue && revenue.length > 0) { %>
    <div class="bg-green-50 border border-green-200 rounded-xl px-4 py-2 text-sm text-green-700">
      <i class="fas fa-euro-sign mr-1"></i>
      Total complété: <strong><%= revenue.reduce((a,r) => a + (parseFloat(r.total)||0), 0).toFixed(2) %> €</strong>
    </div>
  <% } %>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr class="text-xs text-gray-500 uppercase tracking-wider">
          <th class="text-left px-5 py-3 font-medium">Utilisateur</th>
          <th class="text-left px-5 py-3 font-medium">Plan</th>
          <th class="text-left px-5 py-3 font-medium">Méthode</th>
          <th class="text-left px-5 py-3 font-medium">Montant</th>
          <th class="text-left px-5 py-3 font-medium">Statut</th>
          <th class="text-left px-5 py-3 font-medium">ID Paiement</th>
          <th class="text-left px-5 py-3 font-medium">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% payments.forEach(p => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-4">
              <p class="font-medium text-gray-900"><%= p.fullname || 'N/A' %></p>
              <p class="text-xs text-gray-400"><%= p.email || '' %></p>
            </td>
            <td class="px-5 py-4 capitalize text-gray-700"><%= p.plan %></td>
            <td class="px-5 py-4">
              <span class="flex items-center space-x-1">
                <i class="<%= p.payment_method === 'stripe' ? 'fab fa-cc-stripe text-blue-500' : 'fab fa-paypal text-blue-600' %> text-lg"></i>
                <span class="capitalize text-xs text-gray-600"><%= p.payment_method %></span>
              </span>
            </td>
            <td class="px-5 py-4 font-bold text-gray-900"><%= parseFloat(p.amount).toFixed(2) %> €</td>
            <td class="px-5 py-4">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium
                <%= p.status === 'completed' ? 'bg-green-100 text-green-700' :
                    p.status === 'pending'   ? 'bg-yellow-100 text-yellow-700' :
                    p.status === 'refunded'  ? 'bg-blue-100 text-blue-700' :
                                               'bg-red-100 text-red-700' %>">
                <%= p.status %>
              </span>
            </td>
            <td class="px-5 py-4">
              <code class="text-xs text-gray-400 bg-gray-50 px-1 rounded">
                <%= (p.payment_intent_id || '').substring(0, 20) %><% if ((p.payment_intent_id||'').length > 20) { %>...<% } %>
              </code>
            </td>
            <td class="px-5 py-4 text-gray-400 text-xs"><%= new Date(p.created_at).toLocaleDateString('fr-BE') %></td>
          </tr>
        <% }) %>
        <% if (payments.length === 0) { %>
          <tr><td colspan="7" class="py-10 text-center text-gray-400"><i class="fas fa-inbox text-2xl mb-2 block"></i>Aucun paiement</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% if (pages > 1) { %>
    <div class="border-t border-gray-100 px-5 py-3 flex items-center justify-between">
      <p class="text-sm text-gray-500">Page <%= page %> / <%= pages %></p>
      <div class="flex space-x-1">
        <% for (let i = Math.max(1, page-3); i <= Math.min(pages, page+3); i++) { %>
          <a href="?page=<%= i %>"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-sm <%= i === page ? 'bg-green-600 text-white' : 'hover:bg-gray-100 text-gray-600' %>">
            <%= i %>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
<%- include('layout_end') %>

