<%- include('../layout/header') %>
<div class="max-w-3xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Mon Profil</h1>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Profile Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 text-center">
      <div class="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="text-white text-3xl font-bold"><%= user.fullname.charAt(0).toUpperCase() %></span>
      </div>
      <h2 class="font-bold text-gray-900 text-lg"><%= user.fullname %></h2>
      <p class="text-gray-500 text-sm"><%= user.email %></p>
      <div class="mt-3">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
          <% if (user.profession === 'medecin') { %>👨‍⚕️ Médecin
          <% } else if (user.profession === 'veterinaire') { %>🐾 Vétérinaire
          <% } else if (user.profession === 'pharmacien') { %>💊 Pharmacien
          <% } else { %>👤 Utilisateur<% } %>
        </span>
      </div>
      <p class="text-xs text-gray-400 mt-3">Membre depuis <%= new Date(user.created_at).toLocaleDateString('fr-BE') %></p>
    </div>
    <!-- Subscription Card -->
    <div class="md:col-span-2 space-y-4">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4"><i class="fas fa-crown mr-2 text-yellow-500"></i>Abonnement actuel</h3>
        <% if (user.plan) { %>
          <div class="flex items-center justify-between p-4 bg-blue-50 rounded-xl mb-4">
            <div>
              <p class="font-bold text-blue-900 capitalize"><%= user.plan %></p>
              <p class="text-sm text-blue-600">
                <% if (user.daily_limit === -1) { %>Questions illimitées
                <% } else { %><%= user.daily_limit %> questions/jour<% } %>
              </p>
            </div>
            <div class="text-3xl">
              <% if (user.plan === 'professionnel') { %>💼
              <% } else if (user.plan === 'bienvenue') { %>⭐
              <% } else { %>🆓<% } %>
            </div>
          </div>
          <% if (user.end_date) { %>
            <p class="text-sm text-gray-500"><i class="fas fa-calendar mr-2"></i>Expire le: <%= new Date(user.end_date).toLocaleDateString('fr-BE') %></p>
          <% } %>
        <% } else { %>
          <p class="text-gray-500 text-sm">Aucun abonnement actif</p>
        <% } %>
        <div class="mt-4">
          <a href="/subscription/plans" class="inline-flex items-center bg-blue-600 text-white text-sm px-5 py-2 rounded-lg hover:bg-blue-700 transition">
            <i class="fas fa-arrow-up mr-2"></i>Améliorer mon plan
          </a>
        </div>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4"><i class="fas fa-link mr-2 text-gray-400"></i>Actions rapides</h3>
        <div class="grid grid-cols-2 gap-3">
          <a href="/chat" class="flex items-center p-3 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition text-sm text-gray-700">
            <i class="fas fa-comment-dots mr-2 text-blue-500"></i>Chatbot
          </a>
          <a href="/chat/history" class="flex items-center p-3 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition text-sm text-gray-700">
            <i class="fas fa-history mr-2 text-purple-500"></i>Historique
          </a>
          <a href="/subscription/plans" class="flex items-center p-3 bg-gray-50 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition text-sm text-gray-700">
            <i class="fas fa-crown mr-2 text-yellow-500"></i>Plans
          </a>
          <a href="/auth/logout" class="flex items-center p-3 bg-gray-50 rounded-xl hover:bg-red-50 hover:text-red-600 transition text-sm text-gray-700">
            <i class="fas fa-sign-out-alt mr-2 text-red-500"></i>Déconnexion
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../layout/footer') %>

