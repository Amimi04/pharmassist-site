<%- include('../layout/header') %>
<div class="max-w-4xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Mon Historique</h1>
      <p class="text-gray-500 text-sm mt-1"><%= messages.length %> conversation(s) enregistrée(s)</p>
    </div>
    <a href="/chat" class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition text-sm font-medium">
      <i class="fas fa-plus mr-2"></i>Nouvelle question
    </a>
  </div>

  <% if (messages.length === 0) { %>
    <div class="text-center py-20 text-gray-400">
      <i class="fas fa-history text-5xl mb-4"></i>
      <p class="text-lg font-medium">Aucun historique</p>
      <p class="text-sm mt-1">Posez votre première question!</p>
      <a href="/chat" class="mt-4 inline-block bg-blue-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-blue-700 transition">Démarrer</a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% messages.forEach(msg => { %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="p-5 border-b border-gray-50">
            <div class="flex items-start space-x-3">
              <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center flex-shrink-0">
                <i class="fas fa-user text-white text-xs"></i>
              </div>
              <div class="flex-1">
                <p class="text-gray-800 font-medium text-sm"><%= msg.question %></p>
                <p class="text-gray-400 text-xs mt-1"><i class="fas fa-clock mr-1"></i><%= new Date(msg.created_at).toLocaleString('fr-BE') %></p>
              </div>
            </div>
          </div>
          <% if (msg.answer) { %>
            <div class="p-5 bg-gray-50">
              <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-teal-500 rounded-full flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-pills text-white text-xs"></i>
                </div>
                <div class="flex-1 text-sm text-gray-600 leading-relaxed">
                  <%- msg.answer.replace(/\n/g, '<br>').substring(0, 500) %>
                  <% if (msg.answer.length > 500) { %><span class="text-gray-400">...</span><% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../layout/footer') %>

